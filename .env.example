# Copy this file to `.env` and fill in real values. Do NOT commit `.env`.
# Vite requires env vars that start with VITE_ to be exposed to the client.

# Supabase
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=public-anon-key

# Optional: other app-specific variables
# e.g. VITE_APP_NAME=AUSDAV

# Facebook Graph API (server-side secrets for Supabase Edge Function)
# IMPORTANT: Do not prefix these with VITE_. Keep them only in server secrets.
# For local Supabase Edge runtime, configure in `supabase/functions/.env`.
# For hosted Supabase, set with: supabase secrets set KEY=VALUE
FACEBOOK_GRAPH_VERSION=v25.0
FACEBOOK_APP_ID=your_meta_app_id
FACEBOOK_APP_SECRET=your_meta_app_secret
FACEBOOK_SYSTEM_USER_TOKEN=your_meta_system_user_token
# Backward compatibility: FACEBOOK_USER_ACCESS_TOKEN is still supported temporarily.
FACEBOOK_PAGE_ID=your_facebook_page_id
# Optional: if you already have a long-lived page token, set it directly.
FACEBOOK_PAGE_ACCESS_TOKEN=your_page_access_token
# Optional CSRF/origin hardening for the import endpoint
FACEBOOK_IMPORT_ALLOWED_ORIGINS=https://www.ausdav.org,http://localhost:5173

# Note: after creating `.env`, restart the dev server.
